{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Resume Analyzer app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "tier": { "type": "string", "enum": ["free", "pro"], "description": "The user's subscription tier." },
        "usageCount": { "type": "number", "description": "The number of analyses the user has performed." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "role", "tier", "usageCount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles, including their role and subscription tier."
    }
  }
}
